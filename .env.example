VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ═══════════════════════════════════════════════════════════
# Firebase Configuration for Phone Authentication
# ═══════════════════════════════════════════════════════════
# Get from: https://console.firebase.google.com/ → Project Settings → General → Your apps
# The config should be a JSON string like:
# {"apiKey":"your-api-key","authDomain":"your-project.firebaseapp.com","projectId":"your-project","storageBucket":"your-project.appspot.com","messagingSenderId":"123456789","appId":"1:123456789:web:abcdef123456"}
VITE_FIREBASE_CONFIG={"apiKey":"your-api-key","authDomain":"your-project.firebaseapp.com","projectId":"your-project-id","storageBucket":"your-project.appspot.com","messagingSenderId":"123456789","appId":"1:123456789:web:abcdef123"}

# Use rzp_test_ prefix for testing, rzp_live_ prefix for production
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_here

# ═══════════════════════════════════════════════════════════
# WhatsApp Business API Configuration
# ═══════════════════════════════════════════════════════════

# Choose provider: 'twilio' or 'interakt'
VITE_WHATSAPP_PROVIDER=twilio

# ─── Twilio Configuration ───
# Get from: https://console.twilio.com/
VITE_TWILIO_ACCOUNT_SID=your_twilio_account_sid
VITE_TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Format: whatsapp:+14155238886 (Twilio sandbox number)
VITE_TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── Interakt Configuration ───
# Get from: https://www.interakt.shop/
VITE_INTERAKT_API_KEY=your_interakt_api_key

# Order tracking URL (optional - defaults to site origin)
VITE_TRACK_ORDER_URL=https://your-domain.com/track-order
